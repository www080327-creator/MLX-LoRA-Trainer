#!/bin/bash

export PATH="/Users/perry_guo/miniforge3/envs/llamafactory/bin:/usr/bin:/bin:/usr/sbin"
export CONDA_PREFIX="/Users/perry_guo/miniforge3/envs/llamafactory"

PIDFILE="/tmp/mlx_train.pid"

# 杀掉旧进程
if [ -f "$PIDFILE" ]; then
    OLD_PID=$(cat "$PIDFILE")
    kill "$OLD_PID" 2>/dev/null
    sleep 1
    kill -9 "$OLD_PID" 2>/dev/null
    rm -f "$PIDFILE"
fi

# 清端口
/usr/sbin/lsof -ti:7878 | /usr/bin/xargs kill -9 2>/dev/null
sleep 1

# 启动（pywebview 原生窗口，无需浏览器）
/Users/perry_guo/miniforge3/envs/llamafactory/bin/python3 "/Users/perry_guo/Desktop/MLX训练.app/Contents/MacOS/mlx_lora_tool.py" &
echo $! > "$PIDFILE"

wait
